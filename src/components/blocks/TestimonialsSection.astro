---
// src/components/blocks/TestimonialsSection.astro
import { getCollection } from 'astro:content';

interface Props {
  waveBg?: string;
}

const { waveBg = 'white' } = Astro.props;
const testimonials = await getCollection('testimonials');
---

<!-- Wave divider into sage (from white/cream above) -->
<div class={`bg-${waveBg} overflow-hidden leading-[0]`}>
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M0,20 C360,55 1080,0 1440,30 L1440,60 L0,60 Z" fill="#EBF5EE" />
  </svg>
</div>

<section class="bg-sage py-24" aria-label="Customer testimonials">
  <div style="max-width: var(--container-max)" class="mx-auto px-6">
    <!-- Section label -->
    <div class="flex flex-col items-center mb-12">
      <span class="inline-block px-4 py-1.5 bg-white border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em] mb-4">
        What Our Clients Say
      </span>
      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center leading-[1.15] max-w-[520px]">
        Real Stories from Real Families
      </h2>
    </div>

    <!-- Testimonial cards grid -->
    <div id="testimonials-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white rounded-[20px] p-8 flex flex-col" style="box-shadow: 0 8px 32px rgba(93,70,40,0.12)">
          <!-- Star rating -->
          <div class="flex items-center gap-1 mb-4" aria-label={`${t.data.rating} out of 5 stars`}>
            {Array.from({ length: 5 }, (_, i) => (
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill={i < t.data.rating ? '#D97706' : '#D9D0C2'}
                aria-hidden="true"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Quote text -->
          <p class="text-[15px] text-brown-mid leading-[1.85] italic mb-6 flex-1">
            "{t.data.text}"
          </p>

          <!-- Author info -->
          <div class="flex items-center justify-between gap-3 flex-wrap">
            <div>
              <div class="font-semibold text-brown-dark text-[15px]">{t.data.name}</div>
              <div class="text-[13px] text-brown-light">{t.data.location}</div>
            </div>
            <span class="bg-sage text-forest text-[11px] px-3 py-1 rounded-pill font-semibold whitespace-nowrap border border-[#B7DFC5]">
              {t.data.plan_type}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      gsap.from('#testimonials-grid > *', {
        opacity: 0,
        y: 30,
        duration: 0.6,
        stagger: 0.1,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '#testimonials-grid',
          start: 'top 80%',
          once: true,
        },
      });
    });
  });
</script>
