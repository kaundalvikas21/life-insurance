---
// src/components/blocks/TrustBar.astro

const badges = [
  {
    label: 'A.M. Best Rated',
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  },
  {
    label: 'Licensed in 49 States',
    icon: `<path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>`,
  },
  {
    label: 'No Medical Exam Required',
    icon: `<path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>`,
  },
  {
    label: 'Same-Day Coverage Available',
    icon: `<path d="M7 2v11h3v9l7-12h-4l4-8z"/>`,
  },
];
---

<div class="bg-white border-y border-[#D9D0C2] py-5">
  <div style="max-width: var(--container-max)" class="mx-auto px-6">
    <div class="flex flex-wrap items-center justify-center gap-6">
      {badges.map(({ label, icon }) => (
        <div class="flex items-center gap-2">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="#2D6A4F"
            aria-hidden="true"
            class="shrink-0"
          >
            <Fragment set:html={icon} />
          </svg>
          <span class="text-[13px] font-semibold text-brown-dark">{label}</span>
        </div>
      ))}
    </div>
  </div>
</div>
