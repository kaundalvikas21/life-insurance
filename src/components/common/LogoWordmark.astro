---
// src/components/common/LogoWordmark.astro
interface Props {
  href?: string;
  tone?: 'light' | 'dark';
}

const { href = '/', tone = 'light' } = Astro.props;
const isDark = tone === 'dark';

const topTextTone = isDark ? 'text-[#E9DCC6]/82' : 'text-brown-mid';
const topRuleTone = isDark ? 'bg-[#C9B99A]/45' : 'bg-brown-mid/40';
const wordmarkTone = isDark ? 'text-white' : 'text-forest-dark';
const accentTone = isDark ? 'bg-[#D8C7AA]' : 'bg-amber/70';
const baselineTone = isDark ? 'bg-[#C9B99A]/45' : 'bg-forest/30';
const ringTone = isDark ? 'focus-visible:ring-[#C9B99A]/45' : 'focus-visible:ring-forest/35';
---

<a
  href={href}
  class:list={[
    'group inline-flex flex-col leading-none no-underline select-none rounded-[6px] focus-visible:outline-none focus-visible:ring-2',
    ringTone,
  ]}
  aria-label="LifeInsuranceCoverage.co home"
>
  <span class:list={[
    'inline-flex items-center gap-2 font-display uppercase tracking-[0.24em] font-semibold text-[9px] sm:text-[10px]',
    topTextTone,
  ]}>
    <span class:list={[
      'h-[1px] w-[10px] rounded-pill transition-all duration-300 ease-out group-hover:w-[14px]',
      topRuleTone,
    ]} aria-hidden="true" />
    Life Insurance
    <span class:list={[
      'h-[1px] w-[10px] rounded-pill transition-all duration-300 ease-out group-hover:w-[14px]',
      topRuleTone,
    ]} aria-hidden="true" />
  </span>

  <span class="inline-flex items-end mt-[2px]">
    <span class:list={[
      'font-display font-black tracking-[-0.022em] text-[20px] sm:text-[22px] transition-[letter-spacing,transform] duration-300 ease-out group-hover:tracking-[-0.008em] group-hover:-translate-y-[0.5px]',
      wordmarkTone,
    ]}>
      Coverage
    </span>
    <span class:list={[
      'mb-[4px] ml-[5px] h-[5px] w-[5px] rounded-[1px] rotate-45 transition-transform duration-300 ease-out group-hover:rotate-90',
      accentTone,
    ]} aria-hidden="true" />
  </span>

  <span class="relative mt-[3px] h-[4px] w-[124px]" aria-hidden="true">
    <span
      class:list={[
        'absolute left-0 top-1/2 h-[1.5px] w-full -translate-y-1/2 rounded-pill origin-left transition-transform duration-300 ease-out group-hover:scale-x-[1.045]',
        baselineTone,
      ]}
    />
    <span
      class:list={[
        'absolute left-1/2 top-1/2 h-[4px] w-[4px] -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-[1px] transition-transform duration-300 ease-out group-hover:rotate-90',
        accentTone,
      ]}
    />
  </span>
</a>
