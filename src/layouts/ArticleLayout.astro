---
// src/layouts/ArticleLayout.astro
import Layout from './Layout.astro';
import PageHero from '../components/blocks/PageHero.astro';
import BottomCTA from '../components/blocks/BottomCTA.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
  breadcrumb?: string;
}

const { title, description = '', lastUpdated, breadcrumb } = Astro.props;
---

<Layout title={`${title} — Life Insurance Coverage`} description={description}>
  <PageHero title={title} subtitle={description} breadcrumb={breadcrumb} />

  <article class="bg-cream py-16">
    <div class="max-w-[800px] mx-auto px-6">
      {breadcrumb && (
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-1.5 text-[13px] text-brown-light flex-wrap">
            <li><a href="/" class="hover:text-forest transition-colors">Home</a></li>
            <li aria-hidden="true" class="text-brown-light/50">›</li>
            <li class="text-brown-dark font-medium">{breadcrumb}</li>
          </ol>
        </nav>
      )}
      {lastUpdated && (
        <p class="text-[13px] text-brown-light mb-8">Last updated: {lastUpdated}</p>
      )}
      <div class="prose-content">
        <slot />
      </div>
    </div>
  </article>

  <BottomCTA />
</Layout>

<style>
  /* Scoped styles don't reach slotted content — use :global() for slot children */
  .prose-content :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    color: #2D2412;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #E8DDD0;
    line-height: 1.2;
  }
  .prose-content :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: #2D6A4F;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .prose-content :global(p) {
    font-size: 16px;
    line-height: 1.85;
    color: #5C4A28;
    margin-bottom: 1.25rem;
  }
  .prose-content :global(ul) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }
  .prose-content :global(ul li) {
    font-size: 15px;
    line-height: 1.8;
    color: #5C4A28;
    margin-bottom: 0.4rem;
  }
  .prose-content :global(a) {
    color: #2D6A4F;
    text-decoration: underline;
  }
  .prose-content :global(a:hover) {
    color: #1B4332;
  }
</style>
