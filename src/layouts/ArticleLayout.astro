---
// src/layouts/ArticleLayout.astro
import Layout from './Layout.astro';
import PageHero from '../components/blocks/PageHero.astro';
import BottomCTA from '../components/blocks/BottomCTA.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
  breadcrumb?: string;
}

const { title, description = '', lastUpdated, breadcrumb } = Astro.props;
---

<Layout title={`${title} — Patriot American Benefits`} description={description}>
  <PageHero title={title} subtitle={description} breadcrumb={breadcrumb} />

  <article class="bg-cream py-16">
    <div class="max-w-[800px] mx-auto px-6">
      {lastUpdated && (
        <p class="text-[13px] text-brown-light mb-8">Last updated: {lastUpdated}</p>
      )}
      <div class="prose-content">
        <slot />
      </div>
    </div>
  </article>

  <BottomCTA />
</Layout>

<style>
  .prose-content h2 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: #2D2412;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-content h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: #2D2412;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-content p {
    font-size: 16px;
    line-height: 1.85;
    color: #5C4A28;
    margin-bottom: 1.25rem;
  }
  .prose-content ul {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }
  .prose-content ul li {
    font-size: 15px;
    line-height: 1.8;
    color: #5C4A28;
    margin-bottom: 0.4rem;
  }
  .prose-content a {
    color: #2D6A4F;
    text-decoration: underline;
  }
  .prose-content a:hover {
    color: #1B4332;
  }
</style>
