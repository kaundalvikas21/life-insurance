---
// src/pages/services/index.astro

import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/blocks/PageHero.astro';
import TrustBar from '../../components/blocks/TrustBar.astro';
import BottomCTA from '../../components/blocks/BottomCTA.astro';
---

<Layout
  title="Our Insurance Services — Life Insurance Coverage"
  description="Final expense, term life, and whole life insurance. We shop 13 carriers to find the right coverage at the best rate for you — at no cost."
>
  <PageHero
    title="Our Insurance Services"
    subtitle="We compare 13 carriers and find your best rate. There's no fee for this — carriers pay us."
    breadcrumb="Services"
    breadcrumbIcon='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>'
  />

  <TrustBar />

  <!-- Services Grid Section -->
  <section class="bg-cream py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-sage border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          What We Offer
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-4">
        What We Sell
      </h2>

      <p class="text-[17px] text-brown-mid max-w-[540px] mx-auto text-center mb-16">
        Four product types. We'll tell you which one fits your situation after a short conversation.
      </p>

      <div id="services-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Card: Whole Life Insurance -->
        <a href="/services/whole-life" class="bg-white rounded-[20px] p-8 flex flex-col border border-[#E8E0D4] hover:border-forest/40 transition-all group text-brown-dark no-underline hover:shadow-lg">
          <div class="w-12 h-12 rounded-full bg-sage flex items-center justify-center mb-6">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">Whole Life Insurance</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8] mb-6 flex-1">
            Permanent coverage that lasts your entire lifetime with guaranteed cash value growth and fixed premiums that never increase.
          </p>
          <span class="inline-flex items-center gap-1 font-semibold text-[14px] text-forest">
            Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <!-- Card: Final Expense Insurance -->
        <a href="/services/final-expense" class="bg-white rounded-[20px] p-8 flex flex-col border border-[#E8E0D4] hover:border-forest/40 transition-all group text-brown-dark no-underline hover:shadow-lg">
          <div class="w-12 h-12 rounded-full bg-sage flex items-center justify-center mb-6">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">Final Expense Insurance</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8] mb-6 flex-1">
            Covers funeral and burial costs so your family does not have to come up with the money on short notice.
          </p>
          <span class="inline-flex items-center gap-1 font-semibold text-[14px] text-forest">
            Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <!-- Card: Term Life Insurance -->
        <a href="/services/term-life" class="bg-white rounded-[20px] p-8 flex flex-col border border-[#E8E0D4] hover:border-forest/40 transition-all group text-brown-dark no-underline hover:shadow-lg">
          <div class="w-12 h-12 rounded-full bg-sage flex items-center justify-center mb-6">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">Term Life Insurance</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8] mb-6 flex-1">
            Up to $500,000 in coverage starting at $15/month. Choose a 10, 20, or 30-year term — commonly used to cover a mortgage or replace income.
          </p>
          <span class="inline-flex items-center gap-1 font-semibold text-[14px] text-forest">
            Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <!-- Card: Indexed Universal Life (IUL) -->
        <a href="/services/iul" class="bg-white rounded-[20px] p-8 flex flex-col border border-[#E8E0D4] hover:border-forest/40 transition-all group text-brown-dark no-underline hover:shadow-lg">
          <div class="w-12 h-12 rounded-full bg-sage flex items-center justify-center mb-6">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">Indexed Universal Life (IUL)</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8] mb-6 flex-1">
            Permanent coverage with cash value tied to a market index. Used by people who want lifelong protection and a cash reserve they can tap in retirement.
          </p>
          <span class="inline-flex items-center gap-1 font-semibold text-[14px] text-forest">
            Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

      </div>
    </div>
  </section>

  <!-- How We Work For You Section -->
  <!-- Wave divider: cream → sage -->
  <div class="bg-cream overflow-hidden leading-[0]">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,10 C480,40 960,0 1440,25 L1440,40 L0,40 Z" fill="#EBF5EE" />
    </svg>
  </div>

  <section class="bg-sage py-20">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-white border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          Our Process
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-12">
        How This Works
      </h2>

      <div id="process-grid" class="grid grid-cols-1 lg:grid-cols-4 gap-6">

        <!-- Step 01 -->
        <div class="flex flex-col items-center text-center px-6">
          <span class="font-display font-bold text-[72px] leading-none text-forest/20 mb-3" aria-hidden="true">01</span>
          <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-5" style="box-shadow: 0 4px 16px rgba(45,106,79,0.12)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">We Shop All 13 Carriers</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">
            We run your profile through every carrier we work with to find the best rate.
          </p>
        </div>

        <!-- Step 02 -->
        <div class="flex flex-col items-center text-center px-6">
          <span class="font-display font-bold text-[72px] leading-none text-forest/20 mb-3" aria-hidden="true">02</span>
          <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-5" style="box-shadow: 0 4px 16px rgba(45,106,79,0.12)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">No Hidden Fees</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">
            Our service is completely free. Carriers pay us when you get covered.
          </p>
        </div>

        <!-- Step 03 -->
        <div class="flex flex-col items-center text-center px-6">
          <span class="font-display font-bold text-[72px] leading-none text-forest/20 mb-3" aria-hidden="true">03</span>
          <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-5" style="box-shadow: 0 4px 16px rgba(45,106,79,0.12)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">Licensed Advisors Only</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">
            You'll always speak with a licensed agent, not a call center rep reading from a script.
          </p>
        </div>

        <!-- Step 04 -->
        <div class="flex flex-col items-center text-center px-6">
          <span class="font-display font-bold text-[72px] leading-none text-forest/20 mb-3" aria-hidden="true">04</span>
          <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-5" style="box-shadow: 0 4px 16px rgba(45,106,79,0.12)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
              <circle cx="12" cy="14" r="2"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">Access Your Cash</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">
            For permanent policies, you can tap your cash value for anything — a loan, a withdrawal, or income in retirement.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Comparison Table Section -->
  <!-- Wave divider: sage → cream -->
  <div class="bg-sage overflow-hidden leading-[0]">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,15 C360,40 1080,0 1440,20 L1440,40 L0,40 Z" fill="#F5F0E8" />
    </svg>
  </div>

  <section class="bg-cream py-20">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-sage border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Compare Plans
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-12">
        Side-by-Side Comparison
      </h2>

      <p class="text-center text-[13px] text-brown-light mb-3 md:hidden">Swipe to compare →</p>
      <div class="max-w-[1000px] mx-auto overflow-x-auto">
        <table class="w-full border-collapse rounded-[16px] overflow-hidden" style="min-width: 560px; box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <thead>
            <tr>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">Feature</th>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">Final Expense</th>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">Term Life</th>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">Whole Life</th>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">IUL</th>
            </tr>
          </thead>
          <tbody>
            <!-- Row 1 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Coverage Duration</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Lifetime</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">10–30 years</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Lifetime</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Lifetime</td>
            </tr>
            <!-- Row 2 -->
            <tr class="bg-cream">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Medical Exam</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </span> No exam
              </td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </span> No exam
              </td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">May be required</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">May be required</td>
            </tr>
            <!-- Row 3 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Coverage Amount</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">$5K–$50K</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">$50K–$500K</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">$10K–$500K</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">$25K–$500K</td>
            </tr>
            <!-- Row 4 -->
            <tr class="bg-cream">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Starting Price</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">~$9/mo</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">~$15/mo</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">~$25/mo</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">~$20/mo</td>
            </tr>
            <!-- Row 5 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Cash Value</td>
              <td class="text-[14px] text-brown-light py-4 px-6 text-center">—</td>
              <td class="text-[14px] text-brown-light py-4 px-6 text-center">—</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Yes
                </span>
              </td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Yes
                </span>
              </td>
            </tr>
            <!-- Row 6 -->
            <tr class="bg-cream">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Age Range</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">45–85</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">18–70</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">0–85</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">20–60</td>
            </tr>
            <!-- Row 7 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Guaranteed Issue</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Available
                </span>
              </td>
              <td class="text-[14px] text-brown-light py-4 px-6 text-center">—</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Some carriers</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Some carriers</td>
            </tr>
            <!-- Row 8 -->
            <tr class="bg-cream">
