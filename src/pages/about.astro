---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/blocks/PageHero.astro';
import TrustBar from '../components/blocks/TrustBar.astro';
import StatsBar from '../components/blocks/StatsBar.astro';
import BottomCTA from '../components/blocks/BottomCTA.astro';
---

<Layout
  title="About Us — Life Insurance Coverage"
  description="Learn about Life Insurance Coverage. We protect American families with affordable final expense coverage. Licensed agents in 49 states since 2021."
>
  <PageHero
    title="About Life Insurance Coverage"
    subtitle="We're an independent insurance agency founded in 2021. Licensed in 49 states, we help people find life insurance without the runaround."
    breadcrumb="About Us"
    breadcrumbIcon='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>'
  />

  <TrustBar />

  <!-- Mission & Vision Section -->
  <section class="bg-cream py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-sage border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.26A7 7 0 0 1 12 2z"/></svg>
          Our Story
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-16">
        Our Mission
      </h2>

      <div id="mission-vision-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Mission -->
        <div class="border-l-4 border-forest pl-8">
          <h3 class="font-display font-bold text-[24px] text-forest mb-5">Our Mission</h3>
          <p class="text-[17px] text-brown-mid leading-[1.85]">
            We started this agency because buying life insurance is needlessly confusing — too many carriers, too many websites asking for your phone number before showing you a quote. We cut through that by doing the comparison work ourselves and presenting you with your actual best option.
          </p>
        </div>

        <!-- Vision -->
        <div class="border-l-4 border-amber pl-8">
          <h3 class="font-display font-bold text-[24px] text-amber-dark mb-5">How We Work</h3>
          <p class="text-[17px] text-brown-mid leading-[1.85]">
            We're independent, which means we work for you — not for any single carrier. We run your profile through all <span class="font-extrabold text-amber bg-amber/10 px-1.5 py-0.5 rounded-md whitespace-nowrap">13 carriers</span> we work with and tell you exactly which one gives you the best rate for your situation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values Section -->
  <!-- Wave divider: cream → sage -->
  <div class="bg-cream overflow-hidden leading-[0]">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,10 C480,40 960,0 1440,25 L1440,40 L0,40 Z" fill="#EBF5EE" />
    </svg>
  </div>

  <section class="bg-sage py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-white border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          What We Won't Do
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-12">
        How We Actually Work
      </h2>

      <div id="values-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Integrity First -->
        <div class="bg-white rounded-[20px] p-8" style="box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <div class="w-12 h-12 bg-sage rounded-xl flex items-center justify-center mb-6">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[22px] text-brown-dark mb-3">We don't push the wrong plan</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">We don't push products that pay us the highest commission. If a plan isn't right for you, we'll say so.</p>
        </div>

        <!-- True Accessibility -->
        <div class="bg-white rounded-[20px] p-8" style="box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <div class="w-12 h-12 bg-sage rounded-xl flex items-center justify-center mb-6">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[22px] text-brown-dark mb-3">Previous declines don't stop us</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">We work with carriers that offer guaranteed issue plans — so previous declines or health conditions don't automatically disqualify you.</p>
        </div>

        <!-- Deep Expertise -->
        <div class="bg-white rounded-[20px] p-8" style="box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <div class="w-12 h-12 bg-sage rounded-xl flex items-center justify-center mb-6">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[22px] text-brown-dark mb-3">Every agent is licensed</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">Every agent is licensed. You'll never end up talking to someone reading from a script.</p>
        </div>

        <!-- Genuine Respect -->
        <div class="bg-white rounded-[20px] p-8" style="box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <div class="w-12 h-12 bg-sage rounded-xl flex items-center justify-center mb-6">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[22px] text-brown-dark mb-3">We don't rush the call</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">We don't rush the call. If you have questions, we answer them — all of them.</p>
        </div>
      </div>
    </div>
  </section>

  <StatsBar />

  <BottomCTA />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  document.addEventListener('astro:page-load', () => {
    gsap.registerPlugin(ScrollTrigger);
    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      gsap.from('#mission-vision-grid > *', {
        opacity: 0,
        y: 30,
        duration: 0.7,
        stagger: 0.2,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#mission-vision-grid',
          start: 'top 95%',
          once: true,
        },
      });

      gsap.from('#values-grid > *', {
        opacity: 0,
        y: 40,
        duration: 0.6,
        stagger: 0.1,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '#values-grid',
          start: 'top 95%',
          once: true,
        },
      });
    });
  });
</script>

