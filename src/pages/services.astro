---
// src/pages/services.astro
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import PageHero from '../components/blocks/PageHero.astro';
import TrustBar from '../components/blocks/TrustBar.astro';
import TestimonialsSection from '../components/blocks/TestimonialsSection.astro';
import BottomCTA from '../components/blocks/BottomCTA.astro';
---

<Layout
  title="Our Insurance Services — Patriot American Benefits"
  description="Final expense, term life, and whole life insurance. We shop 13+ carriers to find the right coverage at the best rate for you — at no cost."
>
  <PageHero
    title="Our Insurance Services"
    subtitle="We shop 13+ carriers to find the right coverage at the best rate for you — at no cost."
    breadcrumb="Services"
  />

  <TrustBar />

  <!-- Services Grid Section -->
  <section class="bg-cream py-24">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-block px-4 py-1.5 bg-sage border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          What We Offer
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-4">
        Coverage Built for Every Stage of Life
      </h2>

      <p class="text-[17px] text-brown-mid max-w-[540px] mx-auto text-center mb-16">
        Whether you need final expense protection, income replacement, or permanent coverage — we find the plan that fits your life and budget.
      </p>

      <div id="services-grid" class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Card 1: Final Expense Insurance (Featured) -->
        <div class="bg-white border-2 border-forest rounded-[20px] p-8 flex flex-col relative" style="box-shadow: 0 8px 40px rgba(45,106,79,0.15)">
          <!-- Most Popular Badge -->
          <div class="mb-5">
            <span class="inline-block px-3 py-1 bg-amber text-white rounded-pill text-[11px] font-semibold uppercase tracking-[0.08em]">
              Most Popular
            </span>
          </div>

          <!-- Icon -->
          <div class="w-[42px] h-[42px] flex items-center justify-center mb-5">
            <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>

          <!-- Title -->
          <h3 class="font-display font-bold text-[22px] text-brown-dark mb-2">Final Expense Insurance</h3>

          <!-- Price -->
          <p class="text-forest font-bold text-[24px] mb-1">From $9/mo</p>
          <p class="text-[13px] text-brown-light mb-4">Ages 45–85</p>

          <!-- Description -->
          <p class="text-[15px] text-brown-mid leading-[1.8] mb-6">
            Designed to cover funeral, burial, and end-of-life costs. Protect your family from unexpected financial burden during an already difficult time.
          </p>

          <!-- Features -->
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'No medical exam required',
              'Coverage from $5,000 to $50,000',
              'Day-one coverage available',
              'Guaranteed issue options available',
              'Premiums never increase',
            ].map((feature) => (
              <li class="flex items-start gap-3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 mt-0.5">
                  <circle cx="12" cy="12" r="10" fill="#2D6A4F" fill-opacity="0.12"/>
                  <path d="M8 12l3 3 5-5" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-[14px] text-brown-mid">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href="/quote"
            class="block text-center bg-forest hover:bg-forest-dark text-white font-semibold text-[15px] py-3 px-6 rounded-pill transition-colors duration-200"
          >
            Get a Quote →
          </a>
        </div>

        <!-- Card 2: Term Life Insurance -->
        <div class="bg-white rounded-[20px] p-8 flex flex-col" style="box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <!-- Best Value Badge -->
          <div class="mb-5">
            <span class="inline-block px-3 py-1 bg-sage text-forest rounded-pill text-[11px] font-semibold uppercase tracking-[0.08em]">
              Best Value
            </span>
          </div>

          <!-- Icon -->
          <div class="w-[42px] h-[42px] flex items-center justify-center mb-5">
            <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
              <circle cx="12" cy="16" r="2"/>
            </svg>
          </div>

          <!-- Title -->
          <h3 class="font-display font-bold text-[22px] text-brown-dark mb-2">Term Life Insurance</h3>

          <!-- Price -->
          <p class="text-forest font-bold text-[24px] mb-1">From $15/mo</p>
          <p class="text-[13px] text-brown-light mb-4">Ages 18–70</p>

          <!-- Description -->
          <p class="text-[15px] text-brown-mid leading-[1.8] mb-6">
            Affordable protection for a specific time period. Ideal for income replacement, mortgage protection, and providing for dependents.
          </p>

          <!-- Features -->
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'Coverage from $50,000 to $500,000',
              '10, 20, or 30-year terms available',
              'Level premiums throughout term',
              'Convertible to permanent coverage',
              'Fast online approval process',
            ].map((feature) => (
              <li class="flex items-start gap-3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 mt-0.5">
                  <circle cx="12" cy="12" r="10" fill="#2D6A4F" fill-opacity="0.12"/>
                  <path d="M8 12l3 3 5-5" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-[14px] text-brown-mid">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href="/quote"
            class="block text-center border-2 border-forest text-forest hover:bg-forest hover:text-white font-semibold text-[15px] py-3 px-6 rounded-pill transition-colors duration-200"
          >
            Get a Quote →
          </a>
        </div>

        <!-- Card 3: Whole Life Insurance -->
        <div class="bg-white rounded-[20px] p-8 flex flex-col" style="box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <!-- Long-Term Security Badge -->
          <div class="mb-5">
            <span class="inline-block px-3 py-1 bg-cream text-brown-dark rounded-pill text-[11px] font-semibold uppercase tracking-[0.08em]">
              Long-Term Security
            </span>
          </div>

          <!-- Icon -->
          <div class="w-[42px] h-[42px] flex items-center justify-center mb-5">
            <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>

          <!-- Title -->
          <h3 class="font-display font-bold text-[22px] text-brown-dark mb-2">Whole Life Insurance</h3>

          <!-- Price -->
          <p class="text-forest font-bold text-[24px] mb-1">From $25/mo</p>
          <p class="text-[13px] text-brown-light mb-4">Ages 0–85</p>

          <!-- Description -->
          <p class="text-[15px] text-brown-mid leading-[1.8] mb-6">
            Permanent life insurance that covers you for life. Builds cash value over time that you can borrow against for major expenses.
          </p>

          <!-- Features -->
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'Lifelong coverage guaranteed',
              'Builds cash value over time',
              'Flexible premium payment options',
              'Dividends possible with some policies',
              'Can be used for estate planning',
            ].map((feature) => (
              <li class="flex items-start gap-3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 mt-0.5">
                  <circle cx="12" cy="12" r="10" fill="#2D6A4F" fill-opacity="0.12"/>
                  <path d="M8 12l3 3 5-5" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-[14px] text-brown-mid">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href="/quote"
            class="block text-center border-2 border-forest text-forest hover:bg-forest hover:text-white font-semibold text-[15px] py-3 px-6 rounded-pill transition-colors duration-200"
          >
            Get a Quote →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- How We Work For You Section -->
  <!-- Wave divider: cream → sage -->
  <div class="bg-cream overflow-hidden leading-[0]">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,10 C480,40 960,0 1440,25 L1440,40 L0,40 Z" fill="#EBF5EE" />
    </svg>
  </div>

  <section class="bg-sage py-20">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-block px-4 py-1.5 bg-white border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          Our Process
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-12">
        How We Work For You
      </h2>

      <div id="process-grid" class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Step 01 -->
        <div class="flex flex-col items-center text-center px-6">
          <span class="font-display font-bold text-[72px] leading-none text-forest/20 mb-3" aria-hidden="true">01</span>
          <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-5" style="box-shadow: 0 4px 16px rgba(45,106,79,0.12)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">We Shop All 13 Carriers</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">
            We run your profile through every carrier we work with to find the best rate.
          </p>
        </div>

        <!-- Step 02 -->
        <div class="flex flex-col items-center text-center px-6">
          <span class="font-display font-bold text-[72px] leading-none text-forest/20 mb-3" aria-hidden="true">02</span>
          <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-5" style="box-shadow: 0 4px 16px rgba(45,106,79,0.12)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">No Hidden Fees</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">
            Our service is completely free. Carriers pay us when you get covered.
          </p>
        </div>

        <!-- Step 03 -->
        <div class="flex flex-col items-center text-center px-6">
          <span class="font-display font-bold text-[72px] leading-none text-forest/20 mb-3" aria-hidden="true">03</span>
          <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-5" style="box-shadow: 0 4px 16px rgba(45,106,79,0.12)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#2D6A4F" aria-hidden="true">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[20px] text-brown-dark mb-3">Licensed Advisors Only</h3>
          <p class="text-[15px] text-brown-mid leading-[1.8]">
            You'll always speak with a licensed, trained insurance professional — never a call center script reader.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Comparison Table Section -->
  <!-- Wave divider: sage → cream -->
  <div class="bg-sage overflow-hidden leading-[0]">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,15 C360,40 1080,0 1440,20 L1440,40 L0,40 Z" fill="#F5F0E8" />
    </svg>
  </div>

  <section class="bg-cream py-20">
    <div class="max-w-[1280px] mx-auto px-6">
      <!-- Label pill -->
      <div class="flex justify-center mb-5">
        <span class="inline-block px-4 py-1.5 bg-sage border border-[#B7DFC5] text-forest rounded-pill text-[12px] font-semibold uppercase tracking-[0.14em]">
          Compare Plans
        </span>
      </div>

      <h2 class="font-display font-bold text-[clamp(32px,4vw,42px)] text-brown-dark text-center mb-12">
        Side-by-Side Comparison
      </h2>

      <div class="max-w-[800px] mx-auto overflow-x-auto">
        <table class="w-full border-collapse rounded-[16px] overflow-hidden" style="box-shadow: 0 8px 32px rgba(93,70,40,0.10)">
          <thead>
            <tr>
              <th class="bg-cream py-4 px-6 text-left"></th>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">Final Expense</th>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">Term Life</th>
              <th class="bg-forest-dark text-white font-display font-semibold text-[15px] py-4 px-6 text-center">Whole Life</th>
            </tr>
          </thead>
          <tbody>
            <!-- Row 1 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Coverage Duration</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Lifetime</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">10–30 years</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Lifetime</td>
            </tr>
            <!-- Row 2 -->
            <tr class="bg-cream">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Medical Exam</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </span> No exam
              </td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </span> No exam
              </td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">May be required</td>
            </tr>
            <!-- Row 3 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Coverage Amount</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">$5K–$50K</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">$50K–$500K</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">$10K–$500K</td>
            </tr>
            <!-- Row 4 -->
            <tr class="bg-cream">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Starting Price</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">~$9/mo</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">~$15/mo</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">~$25/mo</td>
            </tr>
            <!-- Row 5 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Cash Value</td>
              <td class="text-[14px] text-brown-light py-4 px-6 text-center">—</td>
              <td class="text-[14px] text-brown-light py-4 px-6 text-center">—</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Yes
                </span>
              </td>
            </tr>
            <!-- Row 6 -->
            <tr class="bg-cream">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Age Range</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">45–85</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">18–70</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">0–85</td>
            </tr>
            <!-- Row 7 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Guaranteed Issue</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Available
                </span>
              </td>
              <td class="text-[14px] text-brown-light py-4 px-6 text-center">—</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Some carriers</td>
            </tr>
            <!-- Row 8 -->
            <tr class="bg-cream">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Day-One Coverage</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Available
                </span>
              </td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">
                <span class="inline-flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#2D6A4F" aria-label="Yes"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Available
                </span>
              </td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Varies</td>
            </tr>
            <!-- Row 9 -->
            <tr class="bg-white">
              <td class="font-semibold text-brown-dark text-[14px] py-4 px-6">Best For</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Seniors &amp; burial costs</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Young families</td>
              <td class="text-[14px] text-brown-mid py-4 px-6 text-center">Estate planning</td>
            </tr>
          </tbody>
        </table>

        <p class="text-[12px] text-brown-light text-center mt-4">
          All rates shown are estimates. Actual rates depend on your age, gender, state, and health status.
        </p>
      </div>
    </div>
  </section>

  <TestimonialsSection waveBg="cream" />

  <BottomCTA />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  document.addEventListener('astro:page-load', () => {
    gsap.registerPlugin(ScrollTrigger);
    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      // Services cards stagger
      gsap.from('#services-grid > *', {
        opacity: 0,
        y: 40,
        duration: 0.7,
        stagger: 0.15,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#services-grid',
          start: 'top 80%',
          once: true,
        },
      });

      // Process steps stagger
      gsap.from('#process-grid > *', {
        opacity: 0,
        y: 30,
        duration: 0.6,
        stagger: 0.15,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '#process-grid',
          start: 'top 80%',
          once: true,
        },
      });
    });
  });
</script>
